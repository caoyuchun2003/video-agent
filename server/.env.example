# 千帆 API Key(v2,格式 bce-v3/ALTAK-xxx/xxx) — 只放服务器,永不进 Git
QIANFAN_API_KEY=bce-v3/ALTAK-your-key/your-secret

# CFC 网关共享密钥,与 CFC 环境变量 GATEWAY_TOKEN 保持一致
# 生成方式:openssl rand -hex 32
GATEWAY_TOKEN=change-me-to-a-random-string

# 熟人访问口令(仅生成视频必填)。空=不校验。勿提交真实口令到 Git
ACCESS_PHRASE=

# 提示词优化用的对话模型
CHAT_MODEL=deepseek-v3.2

# 视频管线:t2i_i2v(文生图→图生视频,默认) | text2video(需开通文生视频)
VIDEO_PIPELINE=t2i_i2v

# 文生图
IMAGE_MODEL=qwen-image
IMAGE_SIZE=1280x720

# 图生视频。模型广场若只有「蒸汽机 Air」，用 musesteamer-air-i2v
# 开通了 2.0/2.1 系列再改成对应 model 名（如 musesteamer-2.1-turbo-i2v）
VIDEO_MODEL=musesteamer-air-i2v

# text2video 时用的 beta 路径
VIDEO_CREATE_PATH=/beta/video/generations/qianfan-video
VIDEO_QUERY_PATH=/beta/video/generations/qianfan-video

# 生成参数
VIDEO_DURATION=5
VIDEO_MODE=std
VIDEO_ASPECT_RATIO=16:9

# 频控:每分钟最多提交任务数 / 同时进行中的任务上限
RATE_PER_MINUTE=2
MAX_ACTIVE_TASKS=3

# 监听端口(与 my-agent 的 8010 错开)
PORT=8001
